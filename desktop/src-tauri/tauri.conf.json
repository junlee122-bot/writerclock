{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AuthorClock",
  "version": "0.1.0",
  "identifier": "io.github.gyuminlee-repo.author-clock",
  "build": {
    "frontendDist": "https://gyuminlee-repo.github.io/author-clock/"
  },
  "app": {
    "windows": [
      {
        "title": "작가시계",
        "width": 520,
        "height": 400,
        "minWidth": 320,
        "minHeight": 240,
        "resizable": true,
        "alwaysOnTop": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
